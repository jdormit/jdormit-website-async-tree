{
  "name": "jdormit-website-async-tree",
  "scripts": {
    "build": "bun scripts/build.ts",
    "dev": "bunx --bun nodemon --watch scripts --watch src -e ts,js,html,css,md --exec 'bun scripts/dev.ts'",
    "format": "bunx --bun prettier --write ."
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "nodemon": "^3.1.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@weborigami/async-tree": "^0.6.15",
    "excerpt-html": "^1.2.2",
    "gray-matter": "^4.0.3",
    "prettier": "^3.8.3"
  }
}
